#!/usr/bin/env python3

import os
import sys
import subprocess

import argparse
parser = argparse.ArgumentParser()
parser.add_argument("--utility",default="",
        help='Just run a single utility script and exit')
args = parser.parse_args() # get the arguments


def get_qhroot():
  """Gets the root path of quantum lattice"""
  return os.path.normpath(os.path.join(os.path.dirname(os.path.realpath(__file__)),".."))

qhroot = get_qhroot()  # get the root path

sys.path.append(os.path.join(qhroot,"pysrc")) # add this path
from interpreter import pycommand
python = pycommand.get_python()


# use a utility and exit
if args.utility!="": # non empty string
  subprocess.run([python,os.path.join(qhroot,"utilities",args.utility)])
  exit()

subprocess.run([python,os.path.join(qhroot,"bin","versions","quantum-lattice-pyqt")])
